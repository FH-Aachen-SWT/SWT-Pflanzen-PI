<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:anim="https://github.com/whistyun/AnimatedImage.Avalonia"

        xmlns:vm="clr-namespace:PflanzenPi.UI.Viewmodel"
        x:DataType="vm:MainViewModel"
        mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="450"
        Height="480" Width="320"  
        MaxHeight="480" MaxWidth="320"
        x:Class="PflanzenPi.UI.View.MainWindow"
        Title="PflanzenPi">
    <Window.Resources>
        <FontFamily x:Key="NameFont">avares://PflanzenPI.Ui/Styles/ari_w9500#Ari-W9500 Bold</FontFamily>
        <SolidColorBrush x:Key="HintergrundWand" Color="#cda07f"></SolidColorBrush>
        <SolidColorBrush x:Key="Boden" Color="#a04e1f"></SolidColorBrush>
        <SolidColorBrush x:Key="Strich" Color="#733512"></SolidColorBrush>
    </Window.Resources>
    <Grid Width="320" Height="480" x:Name="RootGrid"
          Focusable="True"
          Background="Transparent"
          PointerPressed="RootGrid_OnPointerPressed">
        <!-- Hintergrund Grid -->
        <Grid RowDefinitions="70*, 1.75*, 25.75*">
            <Border Grid.Row="0" Background="{StaticResource HintergrundWand}"/>
            <Border Grid.Row="1" Background="{StaticResource Strich}"/>
            <Border Grid.Row="2" Background="{StaticResource Boden}"/>
        </Grid>
        <!-- Moisture Images -->
        <Grid x:Name="MoistureImages" HorizontalAlignment="Left"  VerticalAlignment="Top" Margin="0,80,0,0" PointerPressed="MoistureImages_OnPointerPressed">
            <ItemsControl Grid.Row="0" Margin="10" ItemsSource="{Binding Tamagotchi.CurrentMoistureImages}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Image Margin="1" Source="{Binding}" Width="30" Height="30"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
        
        <!-- Popup for Moisture Behaviours -->
        <Popup x:Name="MoistureBehaviourPopup"
               PlacementTarget="{Binding #MoistureImages}"
               Placement="Right" IsLightDismissEnabled="True"
        >
            <Border Background="Transparent"
                    CornerRadius="8">

                <ComboBox x:Name="PlantTypeComboBox" Width="150"
                          ItemsSource="{Binding AllPlantTypes}"
                          SelectedItem="{Binding Tamagotchi.CurrentPlantType}">
                   <Interaction.Behaviors>
                       <EventTriggerBehavior EventName="SelectionChanged" SourceObject="{Binding #PlantTypeComboBox}">
                           <InvokeCommandAction Command="{Binding Tamagotchi.PlantTypeChangedCommand}" CommandParameter="{Binding #PlantTypeComboBox.SelectedItem}"></InvokeCommandAction>
                       </EventTriggerBehavior>
                   </Interaction.Behaviors>
                </ComboBox>

            </Border>
        </Popup>
        
        <!-- Brightness Images -->
        <Grid x:Name="BrightnessImages" HorizontalAlignment="Right" VerticalAlignment="Top"  Margin="0,80,0,0" PointerPressed="BrightnessImages_OnPointerPressed">
            <ItemsControl Grid.Row="0" Margin="10" ItemsSource="{Binding Tamagotchi.CurrentBrightnessImages}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Image Margin="1" Source="{Binding}" Width="30" Height="30"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
        
        <!-- Popup for brightness behaviours-->
        <Popup x:Name="BrightnessBehavioursPopup"
               PlacementTarget="{Binding #BrightnessImages}"
               Placement="Left" IsLightDismissEnabled="True"
        >
            <Border Background="Transparent"
                    CornerRadius="8">

                <ComboBox x:Name="BrightnessTypeComboBox" 
                        Width="150"
                          ItemsSource="{Binding AllBrightnessTypes}"
                          SelectedItem="{Binding Tamagotchi.CurrentBrightnessType}">
                          
                    <Interaction.Behaviors>
                        <EventTriggerBehavior EventName="SelectionChanged" SourceObject="{Binding #BrightnessTypeComboBox}">
                            <InvokeCommandAction Command="{Binding Tamagotchi.BrightnessTypeChangedCommand}" 
                                                 CommandParameter="{Binding #BrightnessTypeComboBox.SelectedItem}"></InvokeCommandAction>
                        </EventTriggerBehavior>
                    </Interaction.Behaviors>
                </ComboBox>

            </Border>
        </Popup>

        
        <!-- Name und Pflanzi-->
        <Grid Width="320" Height="480" RowSpacing="80" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="Auto"/>           
            </Grid.RowDefinitions>
            
            <!-- Border oben -->
            <Border Grid.Row="0"
                    Background="{StaticResource Boden}" 
                    BorderBrush="{StaticResource Strich}"
                    BorderThickness="9"
                    CornerRadius="1"
                    Padding="0,3,0,0"
                    HorizontalAlignment="Center"
                    Margin="0,25,0,0"
                    MinWidth="175">
                <TextBox x:Name="NameTextBox" Text="{Binding Tamagotchi.Name}"
                         Background="Transparent"
                         BorderBrush="Transparent"
                         BorderThickness="0"
                         KeyDown="NameTextBox_OnKeyDown"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"
                         MaxLength="15"
                         FontFamily="{StaticResource NameFont}"
                         FontSize="20">
                    <Interaction.Behaviors>
                        <EventTriggerBehavior EventName="LostFocus" SourceObject="{Binding #NameTextBox}">
                            <InvokeCommandAction Command="{Binding Tamagotchi.NameChangedCommand}" 
                                                 CommandParameter="{Binding #NameTextBox.Text}"></InvokeCommandAction>
                        </EventTriggerBehavior>
                    </Interaction.Behaviors>
                </TextBox>
            </Border>
            
            <!-- Image -->
            <Image x:Name="PlantImage" 
                Grid.Row="1"
                anim:ImageBehavior.AnimatedSource="{Binding Tamagotchi.CurrentMoodImage}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Stretch="None"
                   Margin="0,0,0,0"/>
        </Grid>
        <!-- Next Watering -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="5">

            <Image Width="48" Height="28" Source="../Assets/can.png" Margin="0,0,8,0"/>
            <TextBlock Text="2h"
                       VerticalAlignment="Bottom"/>
        </StackPanel>
        <!-- Streak -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="5">
            
            <TextBlock Text="streak"
                       VerticalAlignment="Bottom"/>
            <Image Width="28" Height="28" Source="../Assets/heart.png" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
